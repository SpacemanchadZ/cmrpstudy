
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ramsey Multicraft Prep · Free Study Guide</title>
<meta name="description" content="Free Ramsey Multicraft test prep — flashcards and practice exam covering Electrical, Mechanical, Hydraulics, Pneumatics, Print Reading, Trade Math, and Safety/LOTO.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#f0ece3;--ink2:#a89f8c;--ink3:#6b6356;
  --bg:#0e0d0b;--bg2:#151310;--bg3:#1c1a16;--bg4:#242018;--bg5:#2c2820;
  --amber:#d4820a;--amber2:#f5a623;
  --amb-bg:rgba(212,130,10,0.08);--amb-bdr:rgba(212,130,10,0.25);
  --rust:#b84a1c;--rust2:#e05c25;--rust-bg:rgba(184,74,28,0.10);--rust-bdr:rgba(184,74,28,0.28);
  --steel:#4a7fa5;--steel2:#6ba3c9;--steel-bg:rgba(74,127,165,0.08);--steel-bdr:rgba(74,127,165,0.25);
  --green:#3d7a4f;--green2:#5aaa70;--grn-bg:rgba(61,122,79,0.10);--grn-bdr:rgba(61,122,79,0.28);
  --violet2:#a78bfa;--vlt-bg:rgba(124,58,237,0.10);--vlt-bdr:rgba(124,58,237,0.28);
  --teal2:#2dd4bf;--teal-bg:rgba(13,148,136,0.10);--teal-bdr:rgba(13,148,136,0.28);
  --bdr:rgba(240,236,227,0.07);--bdr2:rgba(240,236,227,0.14);--bdr3:rgba(240,236,227,0.22);
  --ff-d:'Playfair Display',Georgia,serif;--ff-b:'Outfit',sans-serif;--ff-m:'DM Mono',monospace;
  --r:6px;--rl:12px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--ff-b);background:var(--bg);color:var(--ink);line-height:1.6;font-size:15px;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;opacity:0.025;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-size:200px;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:var(--bg5);border-radius:2px;}

/* NAV */
#nav{position:fixed;top:0;left:0;right:0;z-index:500;height:56px;background:rgba(14,13,11,0.94);backdrop-filter:blur(16px);border-bottom:1px solid var(--bdr);display:flex;align-items:center;padding:0 1.5rem;gap:1.5rem;}
.nav-logo{font-family:var(--ff-m);font-size:0.8rem;font-weight:500;letter-spacing:0.06em;color:var(--ink);display:flex;align-items:center;gap:0.55rem;cursor:pointer;flex-shrink:0;text-decoration:none;}
.nav-logo-dot{width:8px;height:8px;border-radius:50%;background:var(--amber);flex-shrink:0;}
.nav-tabs{display:flex;gap:0.2rem;flex:1;}
.nav-tab{font-size:0.8rem;font-weight:500;color:var(--ink3);padding:0.32rem 0.85rem;border-radius:5px;cursor:pointer;transition:all .14s;border:1px solid transparent;white-space:nowrap;}
.nav-tab:hover{color:var(--ink);background:rgba(255,255,255,0.04);}
.nav-tab.active{color:var(--amber2);border-color:var(--amb-bdr);background:var(--amb-bg);}
.nav-back{font-family:var(--ff-m);font-size:0.72rem;padding:0.35rem 0.9rem;border-radius:5px;border:1px solid var(--bdr2);color:var(--ink2);cursor:pointer;transition:all .15s;text-decoration:none;margin-left:auto;}
.nav-back:hover{border-color:var(--amb-bdr);color:var(--amber2);}

/* PAGES */
.page{display:none;min-height:100vh;padding-top:56px;}
.page.active{display:block;}

/* SHARED */
.container{max-width:1100px;margin:0 auto;padding:0 2rem;}
.eyebrow{font-family:var(--ff-m);font-size:0.6rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--amber2);margin-bottom:0.5rem;display:flex;align-items:center;gap:.6rem;}
.eyebrow::after{content:'';flex:1;max-width:50px;height:1px;background:var(--amb-bdr);}
.page-title{font-family:var(--ff-d);font-size:clamp(1.8rem,4vw,2.6rem);font-weight:700;color:var(--ink);line-height:1.15;margin-bottom:.6rem;}
.page-sub{font-size:.9rem;color:var(--ink2);line-height:1.75;max-width:560px;}
.badge{display:inline-flex;align-items:center;font-family:var(--ff-m);font-size:.62rem;letter-spacing:.06em;padding:.2rem .55rem;border-radius:3px;}
.badge-amb{background:var(--amb-bg);border:1px solid var(--amb-bdr);color:var(--amber2);}
.badge-grn{background:var(--grn-bg);border:1px solid var(--grn-bdr);color:var(--green2);}
.badge-stl{background:var(--steel-bg);border:1px solid var(--steel-bdr);color:var(--steel2);}

/* HOME */
.hero{padding:3.5rem 0 2.5rem;border-bottom:1px solid var(--bdr);}
.stats-row{display:flex;gap:2.5rem;flex-wrap:wrap;margin-top:1.75rem;}
.stat-val{font-family:var(--ff-d);font-size:2rem;font-weight:700;color:var(--amber2);line-height:1;}
.stat-lbl{font-family:var(--ff-m);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-top:.25rem;}
.home-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin:2.5rem 0;}
.home-card{background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--rl);padding:2rem;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;}
.home-card::before{content:'';position:absolute;inset:0;opacity:0;background:radial-gradient(circle at top left,var(--hc-glow,rgba(212,130,10,0.08)) 0%,transparent 60%);transition:opacity .3s;}
.home-card:hover{border-color:var(--bdr2);transform:translateY(-3px);}
.home-card:hover::before{opacity:1;}
.hc-icon{font-size:2rem;margin-bottom:1rem;}
.hc-title{font-family:var(--ff-d);font-size:1.3rem;font-weight:700;color:var(--ink);margin-bottom:.4rem;}
.hc-desc{font-size:.82rem;color:var(--ink2);line-height:1.65;margin-bottom:1rem;}
.hc-meta{display:flex;gap:.5rem;flex-wrap:wrap;}
.hc-arr{font-family:var(--ff-m);font-size:.7rem;color:var(--ink3);margin-top:1rem;transition:all .15s;}
.home-card:hover .hc-arr{color:var(--amber2);}

/* FLASHCARDS */
.fc-hero{padding:2.5rem 0 2rem;border-bottom:1px solid var(--bdr);}
.fc-controls{display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;padding:1.25rem 0;}
.fc-cat-btn{font-family:var(--ff-m);font-size:.65rem;padding:.28rem .7rem;border-radius:3px;border:1px solid var(--bdr2);background:transparent;color:var(--ink3);cursor:pointer;transition:all .14s;letter-spacing:.05em;}
.fc-cat-btn:hover,.fc-cat-btn.active{border-color:var(--amber);color:var(--amber2);background:var(--amb-bg);}
.fc-search{background:var(--bg3);border:1px solid var(--bdr2);border-radius:var(--r);padding:.45rem .85rem;color:var(--ink);font-family:var(--ff-b);font-size:.82rem;outline:none;width:220px;transition:border-color .15s;}
.fc-search:focus{border-color:var(--amb-bdr);}
.fc-count{font-family:var(--ff-m);font-size:.68rem;color:var(--ink3);margin-left:auto;}
.fc-stage{max-width:700px;margin:1.5rem auto;}
.fc-progress-bar{height:3px;background:var(--bg4);border-radius:2px;margin-bottom:1.5rem;overflow:hidden;}
.fc-progress-fill{height:100%;background:linear-gradient(90deg,var(--amber),var(--amber2));border-radius:2px;transition:width .4s ease;}
.fc-card-wrap{perspective:1400px;margin-bottom:1.25rem;}
.fc-card{width:100%;min-height:260px;position:relative;transform-style:preserve-3d;transition:transform .55s cubic-bezier(.4,0,.2,1);cursor:pointer;}
.fc-card.flipped{transform:rotateY(180deg);}
.fc-face{position:absolute;inset:0;backface-visibility:hidden;border-radius:var(--rl);padding:2.5rem;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;}
.fc-front{background:var(--bg3);border:1px solid var(--bdr2);}
.fc-back{background:linear-gradient(135deg,#0a1a10,#101828);border:1px solid var(--grn-bdr);transform:rotateY(180deg);}
.fc-hint{font-family:var(--ff-m);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);margin-bottom:.75rem;}
.fc-domain-tag{font-family:var(--ff-m);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:.18rem .5rem;border-radius:3px;margin-bottom:.85rem;}
.fc-term{font-family:var(--ff-d);font-size:1.55rem;font-weight:700;color:var(--ink);line-height:1.3;}
.fc-ans-lbl{font-family:var(--ff-m);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--green2);margin-bottom:.65rem;}
.fc-def{font-size:.88rem;color:rgba(240,236,227,.82);line-height:1.75;max-width:520px;}
.fc-nav{display:flex;align-items:center;justify-content:center;gap:1rem;}
.fc-nav-btn{font-family:var(--ff-m);font-size:.75rem;padding:.5rem 1.25rem;border-radius:5px;border:1px solid var(--bdr2);background:transparent;color:var(--ink2);cursor:pointer;transition:all .15s;}
.fc-nav-btn:hover{border-color:var(--amber);color:var(--amber2);}
.fc-ctr{font-family:var(--ff-m);font-size:.78rem;color:var(--ink3);min-width:80px;text-align:center;}
.fc-flip-hint{font-family:var(--ff-m);font-size:.62rem;color:var(--ink3);text-align:center;margin-top:.75rem;}
.fc-verdict{display:flex;gap:.6rem;justify-content:center;margin-top:1rem;}
.fc-verdict-btn{font-family:var(--ff-m);font-size:.7rem;padding:.4rem 1.1rem;border-radius:5px;cursor:pointer;transition:all .15s;border:1px solid;}
.fc-known{border-color:var(--grn-bdr);color:var(--green2);background:transparent;}
.fc-known:hover{background:var(--grn-bg);}
.fc-unknown{border-color:var(--rust-bdr);color:var(--rust2);background:transparent;}
.fc-unknown:hover{background:var(--rust-bg);}
.fc-session-stats{display:flex;gap:1.5rem;justify-content:center;margin-top:1.5rem;padding:1.1rem;background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);}
.fcs-item{text-align:center;}
.fcs-val{font-family:var(--ff-m);font-size:1.1rem;font-weight:500;}
.fcs-lbl{font-family:var(--ff-m);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-top:.2rem;}

/* QUIZ */
.quiz-hero{padding:2.5rem 0 2rem;border-bottom:1px solid var(--bdr);}
.quiz-setup{padding:2rem 0;}
.qs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin:1.5rem 0;}
.qs-card{background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);padding:1.1rem;cursor:pointer;transition:all .15s;}
.qs-card:hover,.qs-card.selected{border-color:var(--amb-bdr);background:var(--amb-bg);}
.qs-card.selected .qs-check{opacity:1;}
.qs-check{font-size:.8rem;color:var(--amber2);opacity:0;transition:opacity .15s;}
.qs-title{font-weight:600;font-size:.85rem;color:var(--ink);margin-bottom:.25rem;}
.qs-count{font-family:var(--ff-m);font-size:.62rem;color:var(--ink3);}
.quiz-start-btn{font-family:var(--ff-m);font-size:.78rem;padding:.75rem 2rem;border-radius:6px;background:var(--amber);color:var(--bg);border:none;cursor:pointer;font-weight:500;letter-spacing:.05em;text-transform:uppercase;transition:all .18s;margin-top:.5rem;}
.quiz-start-btn:hover{background:var(--amber2);}
.quiz-active{padding:2rem 0;}
.qa-topbar{display:flex;align-items:center;gap:1.5rem;margin-bottom:1.5rem;padding:.85rem 1.25rem;background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);}
.qa-score{font-family:var(--ff-d);font-size:1.5rem;font-weight:700;color:var(--amber2);}
.qa-score-lbl{font-family:var(--ff-m);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-top:.15rem;}
.qa-prog-wrap{flex:1;}
.qa-prog-lbl{font-family:var(--ff-m);font-size:.62rem;color:var(--ink3);margin-bottom:.35rem;}
.qa-prog-track{height:6px;background:var(--bg5);border-radius:3px;overflow:hidden;}
.qa-prog-fill{height:100%;background:linear-gradient(90deg,var(--green),var(--green2));border-radius:3px;transition:width .5s;}
.qa-reset{font-family:var(--ff-m);font-size:.72rem;padding:.4rem .9rem;border:1px solid var(--bdr2);background:transparent;color:var(--ink2);border-radius:5px;cursor:pointer;transition:all .15s;}
.qa-reset:hover{border-color:var(--rust-bdr);color:var(--rust2);}
.q-block{background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);padding:1.35rem;margin-bottom:1rem;}
.q-meta{display:flex;align-items:center;gap:.6rem;margin-bottom:.65rem;}
.q-num{font-family:var(--ff-m);font-size:.6rem;letter-spacing:.08em;color:var(--amber2);}
.q-text{font-size:.92rem;font-weight:600;color:var(--ink);margin-bottom:1rem;line-height:1.65;}
.q-opts{display:flex;flex-direction:column;gap:.45rem;}
.q-opt{display:flex;align-items:flex-start;gap:.7rem;padding:.65rem .9rem;border-radius:6px;border:1px solid var(--bdr);cursor:pointer;font-size:.84rem;color:var(--ink2);line-height:1.5;transition:all .14s;background:rgba(255,255,255,.02);}
.q-opt:hover:not(.disabled){border-color:var(--bdr2);color:var(--ink);background:rgba(255,255,255,.04);}
.q-opt.correct{border-color:var(--green)!important;background:var(--grn-bg)!important;color:var(--ink)!important;}
.q-opt.incorrect{border-color:var(--rust)!important;background:var(--rust-bg)!important;}
.q-opt.disabled{cursor:not-allowed;}
.q-let{font-family:var(--ff-m);font-size:.68rem;font-weight:500;color:var(--ink3);width:18px;flex-shrink:0;padding-top:1px;}
.q-fb{margin-top:.85rem;padding:.8rem 1rem;border-radius:6px;font-size:.82rem;line-height:1.65;display:none;}
.q-fb.correct{background:var(--grn-bg);border:1px solid var(--grn-bdr);color:#86efac;display:block;}
.q-fb.incorrect{background:var(--rust-bg);border:1px solid var(--rust-bdr);color:#fca5a5;display:block;}
.q-fb strong{color:var(--ink);}
.quiz-results{padding:2.5rem 0;}
.qr-hero{text-align:center;padding:2rem;background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--rl);margin-bottom:2rem;}
.qr-score{font-family:var(--ff-d);font-size:4rem;font-weight:900;color:var(--amber2);line-height:1;}
.qr-pct{font-family:var(--ff-m);font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);margin-top:.4rem;}
.qr-verdict{font-size:1.1rem;font-weight:600;margin-top:.75rem;}
.qr-pass{color:var(--green2);}
.qr-fail{color:var(--rust2);}
.qr-domain-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;margin-bottom:2rem;}
.qr-domain-card{background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);padding:1.1rem;}
.qrd-name{font-weight:600;font-size:.82rem;color:var(--ink);margin-bottom:.5rem;}
.qrd-bar-wrap{height:6px;background:var(--bg5);border-radius:3px;overflow:hidden;margin-bottom:.35rem;}
.qrd-bar{height:100%;border-radius:3px;transition:width .6s ease;}
.qrd-stat{font-family:var(--ff-m);font-size:.65rem;color:var(--ink3);}
.qr-retry-btn{font-family:var(--ff-m);font-size:.78rem;padding:.7rem 1.75rem;border-radius:6px;background:var(--amber);color:var(--bg);border:none;cursor:pointer;font-weight:500;letter-spacing:.05em;text-transform:uppercase;transition:all .18s;}
.qr-retry-btn:hover{background:var(--amber2);}
footer{padding:2.5rem;border-top:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-top:4rem;}
.footer-note{font-family:var(--ff-m);font-size:.63rem;color:var(--ink3);}
.footer-link{font-family:var(--ff-m);font-size:.63rem;color:var(--ink3);cursor:pointer;transition:color .14s;text-decoration:none;}
.footer-link:hover{color:var(--amber2);}
@media(max-width:700px){.home-grid{grid-template-columns:1fr;}.container{padding:0 1.25rem;}.fc-search{width:100%;}}
</style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <div class="nav-logo" onclick="showPage('home')">
    <div class="nav-logo-dot"></div>
    <span>Ramsey<span style="color:var(--amber2);">prep</span></span>
  </div>
  <div class="nav-tabs">
    <div class="nav-tab active" onclick="showPage('home')" id="nl-home">Home</div>
    <div class="nav-tab" onclick="showPage('fc')" id="nl-fc">Flashcards</div>
    <div class="nav-tab" onclick="showPage('qz')" id="nl-qz">Practice Exam</div>
  </div>
  <a class="nav-back" href="https://cmrpstudy.com" target="_blank">← CMRPstudy</a>
</nav>

<!-- HOME PAGE -->
<div class="page active" id="page-home">
  <div class="hero">
    <div class="container">
      <div class="eyebrow">Ramsey Multicraft &middot; Free Prep</div>
      <h1 class="page-title">Ramsey Multicraft<br>Test Prep</h1>
      <p class="page-sub">Free flashcards and practice questions covering every Ramsey Multicraft domain. Built by a maintenance practitioner. No login, no cost, no fluff.</p>
      <div class="stats-row">
        <div><div class="stat-val">120</div><div class="stat-lbl">Flashcards</div></div>
        <div><div class="stat-val">80</div><div class="stat-lbl">Practice questions</div></div>
        <div><div class="stat-val">8</div><div class="stat-lbl">Domains</div></div>
        <div><div class="stat-val">70%</div><div class="stat-lbl">Pass target</div></div>
      </div>
    </div>
  </div>
  <div class="container">
    <div class="home-grid">
      <div class="home-card" onclick="showPage('fc')" style="--hc-glow:rgba(212,130,10,0.08);">
        <div class="hc-icon">&#128198;</div>
        <div class="hc-title">Flashcard Deck</div>
        <div class="hc-desc">120 cards spanning all 8 Ramsey Multicraft domains. Filter by domain, mark known vs. unknown, and track your mastery session by session.</div>
        <div class="hc-meta">
          <span class="badge badge-amb">120 cards</span>
          <span class="badge badge-stl">8 domains</span>
          <span class="badge badge-grn">Track mastery</span>
        </div>
        <div class="hc-arr">Open Flashcards &rarr;</div>
      </div>
      <div class="home-card" onclick="showPage('qz')" style="--hc-glow:rgba(61,122,79,0.08);">
        <div class="hc-icon">&#128221;</div>
        <div class="hc-title">Practice Exam</div>
        <div class="hc-desc">80 multiple-choice questions with full answer explanations. Select all domains or focus on one weak area. Instant feedback on every answer.</div>
        <div class="hc-meta">
          <span class="badge badge-grn">80 questions</span>
          <span class="badge badge-amb">Full explanations</span>
          <span class="badge badge-stl">Domain breakdown</span>
        </div>
        <div class="hc-arr">Start Practice Exam &rarr;</div>
      </div>
    </div>

    <!-- Formula quick reference -->
    <div style="background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--rl);padding:1.5rem;margin-bottom:2rem;">
      <div style="font-family:var(--ff-m);font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--amber2);margin-bottom:1rem;">Key Formulas &mdash; Memorize These</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:1px;background:var(--bdr);border:1px solid var(--bdr);border-radius:var(--r);overflow:hidden;">
        <div style="background:var(--bg3);padding:.85rem 1rem;"><div style="font-family:var(--ff-m);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:.25rem;">Ohm&rsquo;s Law</div><div style="font-family:var(--ff-m);font-size:.85rem;color:var(--amber2);">V = I &times; R</div></div>
        <div style="background:var(--bg3);padding:.85rem 1rem;"><div style="font-family:var(--ff-m);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:.25rem;">Power</div><div style="font-family:var(--ff-m);font-size:.85rem;color:var(--amber2);">P = V &times; I = I&sup2;R</div></div>
        <div style="background:var(--bg3);padding:.85rem 1rem;"><div style="font-family:var(--ff-m);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:.25rem;">Series R</div><div style="font-family:var(--ff-m);font-size:.85rem;color:var(--amber2);">R<sub>T</sub> = R1 + R2 + R3</div></div>
        <div style="background:var(--bg3);padding:.85rem 1rem;"><div style="font-family:var(--ff-m);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:.25rem;">Parallel R</div><div style="font-family:var(--ff-m);font-size:.85rem;color:var(--amber2);">1/R<sub>T</sub> = 1/R1 + 1/R2</div></div>
