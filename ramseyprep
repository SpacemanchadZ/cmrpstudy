var fcActive=CARDS.slice(),fcIdx=0,fcFlipped=false;
var fcKnown=new Set(),fcUnknown=new Set(),fcCatFilter='ALL';

function buildCatBtns(){
  var wrap=document.getElementById('fc-cat-btns');if(!wrap)return;
  ['ALL'].concat(Object.keys(FC_CATS)).forEach(function(c){
    var btn=document.createElement('button');
    btn.className='fc-cat-btn'+(c==='ALL'?' active':'');
    btn.textContent=c==='ALL'?('All ('+CARDS.length+')'):FC_CATS[c].label;
    btn.onclick=function(){
      wrap.querySelectorAll('.fc-cat-btn').forEach(function(b){b.classList.remove('active');});
      btn.classList.add('active');fcCatFilter=c;filterFC();
    };
    wrap.appendChild(btn);
  });
}

function filterFC(){
  var q=((document.getElementById('fc-search')||{}).value||'').toLowerCase().trim();
  fcActive=CARDS.filter(function(f){
    return(fcCatFilter==='ALL'||f.c===fcCatFilter)&&(!q||f.t.toLowerCase().includes(q)||f.d.toLowerCase().includes(q));
  });
  fcIdx=0;fcFlipped=false;
  var cd=document.getElementById('fc-count-display');if(cd)cd.textContent=fcActive.length+' card'+(fcActive.length!==1?'s':'');
  renderFC();
}

function renderFC(){
  var term=document.getElementById('fc-term');if(!term)return;
  if(!fcActive.length){term.textContent='No cards match filter';return;}
  var card=fcActive[fcIdx],cat=FC_CATS[card.c];
  var tag=document.getElementById('fc-domain-tag');
  tag.textContent=cat.label;
  tag.style.cssText='display:inline-block;font-family:var(--ff-m);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:.18rem .6rem;border-radius:3px;margin-bottom:.85rem;background:'+cat.bg+';border:1px solid '+cat.bdr+';color:'+cat.color+';';
  document.getElementById('fc-term').textContent=card.t;
  document.getElementById('fc-def').textContent=card.d;
  document.getElementById('fc-ctr').textContent=(fcIdx+1)+' / '+fcActive.length;
  document.getElementById('fc-prog-fill').style.width=((fcIdx+1)/fcActive.length*100)+'%';
  document.getElementById('fc-card').classList.remove('flipped');
  fcFlipped=false;updateFCStats();
}

function flipFC(){fcFlipped=!fcFlipped;document.getElementById('fc-card').classList.toggle('flipped',fcFlipped);}
function fcMove(dir){if(!fcActive.length)return;fcIdx=(fcIdx+dir+fcActive.length)%fcActive.length;renderFC();}
function markFC(known){
  if(!fcActive.length)return;var t=fcActive[fcIdx].t;
  known?(fcKnown.add(t),fcUnknown.delete(t)):(fcUnknown.add(t),fcKnown.delete(t));
  updateFCStats();setTimeout(function(){fcMove(1);},300);
}
function updateFCStats(){
  var rev=fcKnown.size+fcUnknown.size,pct=CARDS.length?Math.round(fcKnown.size/CARDS.length*100):0;
  var m={'fcs-known':fcKnown.size,'fcs-unknown':fcUnknown.size,'fcs-remaining':CARDS.length-rev,'fcs-pct':pct+'%'};
  Object.keys(m).forEach(function(id){var el=document.getElementById(id);if(el)el.textContent=m[id];});
}
function resetFC(){fcKnown.clear();fcUnknown.clear();fcIdx=0;fcFlipped=false;filterFC();updateFCStats();}

