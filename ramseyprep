{d:'SAFE',q:'SDS Section 8 covers:',o:['Firefighting','Physical/chemical properties','Exposure controls and required PPE','First aid'],a:2,e:'Section 8 = Exposure Controls/PPE: PELs, engineering controls, respiratory protection, gloves, eye/skin protection.'},
{d:'SAFE',q:'In Hierarchy of Controls, PPE is last because:',o:['Most effective','Least effective \u2014 can fail, be worn wrong, or not worn at all','Too expensive','OSHA only requires it last'],a:1,e:'Engineering controls protect everyone automatically. PPE requires correct selection, fit, and use every time.'},
{d:'SAFE',q:'Arc flash PPE level is determined by:',o:['Voltage only','Incident energy (cal/cm\u00b2) from arc flash hazard analysis','Annual policy review','OSHA Table Z-1'],a:1,e:'Incident energy depends on fault current, clearing time, and distance \u2014 not voltage alone.'},
{d:'SAFE',q:'OSHA fall protection in general industry at:',o:['2 ft','4 ft','6 ft','10 ft'],a:1,e:'General industry = 4 ft. Construction = 6 ft. Shipbuilding = 10 ft.'},
{d:'SAFE',q:'Hot work permit required when:',o:['Using any hand tools','Welding, cutting, grinding in areas with fire/explosion hazards','Any outdoor work','Lifting over 50 lbs'],a:1,e:'Required for spark/heat-producing work where flammable/combustible materials may be present.'},
{d:'SAFE',q:'Permit-required confined space contains:',o:['Limited lighting','Hazardous atmosphere, engulfment, entrapment, or other IDLH conditions','Rain water','Poor cell reception'],a:1,e:'Requires permit, trained entrant, outside attendant, atmospheric testing, rescue plan.'},
{d:'SAFE',q:"Heinrich's Triangle explains near miss reporting because:",o:['Near misses cost more','For every major injury: ~29 minor injuries and ~300 near misses \u2014 all share root causes','Creates paperwork','OSHA requires near misses on 300 log'],a:1,e:'Same root causes produce near misses and major injuries. Investigate near misses to prevent major incidents.'},
];

// ── QUIZ STATE ────────────────────────────────────────────────────────────────
var qzActive=[],qzState=[],qzAnswered=0,qzCorrect=0;
var qzDomainFilter=new Set(DOMAINS);

function buildQuizSetup(){
  var grid=document.getElementById('qs-domain-grid');if(!grid)return;
  var counts={};DOMAINS.forEach(function(d){counts[d]=0;});QUESTIONS.forEach(function(q){counts[q.d]++;});
  DOMAINS.forEach(function(d){
    var card=document.createElement('div');card.className='qs-card selected';card.id='qsd-'+d;
    card.innerHTML='<div style="display:flex;justify-content:space-between;align-items:flex-start;"><div class="qs-title">'+DOMAIN_LABELS[d]+'</div><div class="qs-check">\u2713</div></div><div class="qs-count">'+counts[d]+' questions</div>';
    card.onclick=function(){
      if(qzDomainFilter.has(d)){if(qzDomainFilter.size===1)return;qzDomainFilter.delete(d);card.classList.remove('selected');}
      else{qzDomainFilter.add(d);card.classList.add('selected');}
      var ct=QUESTIONS.filter(function(q){return qzDomainFilter.has(q.d);}).length;
      var el=document.getElementById('qs-selected-count');if(el)el.textContent=ct+' question'+(ct!==1?'s':'')+' selected';
    };
    grid.appendChild(card);
  });
}

function startQuiz(){
  qzActive=QUESTIONS.filter(function(q){return qzDomainFilter.has(q.d);});if(!qzActive.length)return;
  qzState=qzActive.map(function(){return{answered:false,correct:false};});qzAnswered=0;qzCorrect=0;
  document.getElementById('quiz-setup').style.display='none';
  document.getElementById('quiz-active').style.display='block';
  document.getElementById('quiz-results').style.display='none';
  buildQuizQuestions();updateQuizScore();
}

function buildQuizQuestions(){
  var wrap=document.getElementById('qa-questions');wrap.innerHTML='';
  var dC={ELEC:'var(--steel2)',MOTOR:'var(--amber2)',MECH:'var(--green2)',HYD:'var(--rust2)',PNEU:'#a78bfa',PRINT:'#2dd4bf',MATH:'var(--amber2)',SAFE:'var(--rust2)'};
  qzActive.forEach(function(q,qi){
    var div=document.createElement('div');div.className='q-block';div.id='qb-'+qi;
    var opts=q.o.map(function(o,oi){return'<div class="q-opt" onclick="answerQ('+qi+','+oi+')" id="qo-'+qi+'-'+oi+'"><span class="q-let">'+'ABCD'[oi]+'</span>'+o+'</div>';}).join('');
    div.innerHTML='<div class="q-meta"><div class="q-num">Question '+(qi+1)+' of '+qzActive.length+'</div><span style="font-family:var(--ff-m);font-size:.58rem;padding:.12rem .45rem;border-radius:3px;background:rgba(255,255,255,.06);color:'+(dC[q.d]||'var(--ink3)')+';">'+DOMAIN_LABELS[q.d]+'</span></div><div class="q-text">'+q.q+'</div><div class="q-opts">'+opts+'</div><div class="q-fb" id="qfb-'+qi+'"></div>';
    wrap.appendChild(div);
  });
}

function answerQ(qi,sel){
  if(qzState[qi].answered)return;
  qzState[qi].answered=true;var correct=sel===qzActive[qi].a;qzState[qi].correct=correct;
  if(correct)qzCorrect++;qzAnswered++;
  for(var i=0;i<qzActive[qi].o.length;i++){var el=document.getElementById('qo-'+qi+'-'+i);el.classList.add('disabled');if(i===qzActive[qi].a)el.classList.add('correct');else if(i===sel)el.classList.add('incorrect');}
  var fb=document.getElementById('qfb-'+qi);fb.className='q-fb '+(correct?'correct':'incorrect');fb.innerHTML='<strong>'+(correct?'\u2713 Correct. ':'\u2717 Incorrect. ')+'</strong>'+qzActive[qi].e;
  updateQuizScore();
  if(qzAnswered===qzActive.length){document.getElementById('qa-results-btn').style.display='block';document.getElementById('qa-results-btn').scrollIntoView({behavior:'smooth',block:'center'});}
}

function updateQuizScore(){
  document.getElementById('qa-score').textContent=qzCorrect+' / '+qzAnswered;
  document.getElementById('qa-prog-lbl').textContent=qzAnswered+' of '+qzActive.length+' answered';
  document.getElementById('qa-prog-fill').style.width=(qzAnswered/qzActive.length*100)+'%';
}

function showResults(){
  document.getElementById('quiz-active').style.display='none';document.getElementById('quiz-results').style.display='block';
  var pct=Math.round(qzCorrect/qzActive.length*100),pass=pct>=70;
  var ds={};DOMAINS.forEach(function(d){ds[d]={correct:0,total:0};});
  qzActive.forEach(function(q,qi){ds[q.d].total++;if(qzState[qi].correct)ds[q.d].correct++;});
  var cards=DOMAINS.filter(function(d){return ds[d].total>0;}).map(function(d){
    var s=ds[d],dp=s.total?Math.round(s.correct/s.total*100):0,bc=dp>=80?'var(--green2)':dp>=60?'var(--amber2)':'var(--rust2)';
    return'<div class="qr-domain-card"><div class="qrd-name">'+DOMAIN_LABELS[d]+'</div><div class="qrd-bar-wrap"><div class="qrd-bar" style="width:'+dp+'%;background:'+bc+';"></div></div><div class="qrd-stat">'+s.correct+'/'+s.total+' correct ('+dp+'%)</div></div>';
  }).join('');
  var weak=DOMAINS.filter(function(d){return ds[d].total>0&&ds[d].correct/ds[d].total<0.70;}).map(function(d){return DOMAIN_LABELS[d];});
  var note=weak.length?'<p style="font-size:.85rem;color:var(--ink2);margin-top:1rem;">Focus study on: <strong style="color:var(--rust2);">'+weak.join(', ')+'</strong></p>':'<p style="font-size:.85rem;color:var(--green2);margin-top:1rem;">Strong across all domains \u2014 keep reviewing.</p>';
  document.getElementById('quiz-results').innerHTML='<div class="qr-hero"><div class="qr-score">'+qzCorrect+'/'+qzActive.length+'</div><div class="qr-pct">'+pct+'% Correct</div><div class="qr-verdict '+(pass?'qr-pass':'qr-fail')+'">'+(pass?'\u2713 Passing Range \u2014 solid work':'\u2717 Below target \u2014 keep reviewing')+'</div><p style="font-size:.82rem;color:var(--ink3);margin-top:.6rem;">Ramsey target: 70%+. Aim for 80%+ for confidence.</p>'+note+'</div><div class="qr-domain-grid">'+cards+'</div><div style="display:flex;gap:1rem;flex-wrap:wrap;"><button class="qr-retry-btn" onclick="resetQuiz()">\u21ba Try Again</button><button class="qr-retry-btn" style="background:var(--bg4);color:var(--ink2);border:1px solid var(--bdr2);" onclick="showPage(\'qz\')">\u2190 Change Domains</button></div>';
  document.getElementById('quiz-results').scrollIntoView({behavior:'smooth'});
}

function resetQuiz(){
  qzAnswered=0;qzCorrect=0;qzState=[];
  document.getElementById('qa-results-btn').style.display='none';
  document.getElementById('quiz-results').style.display='none';
  document.getElementById('quiz-setup').style.display='block';
  document.getElementById('quiz-active').style.display='none';
  document.getElementById('qa-questions').innerHTML='';
  window.scrollTo({top:0,behavior:'smooth'});
}

// ── KEYBOARD NAV ──────────────────────────────────────────────────────────────
document.addEventListener('keydown',function(e){
  var page=document.querySelector('.page.active');if(!page||page.id!=='page-fc')return;
  if(e.key==='ArrowRight')fcMove(1);
  else if(e.key==='ArrowLeft')fcMove(-1);
  else if(e.key===' '||e.key==='Enter'){e.preventDefault();flipFC();}
  else if(e.key==='g'||e.key==='G')markFC(true);
  else if(e.key==='s'||e.key==='S')markFC(false);
});

// ── INIT ──────────────────────────────────────────────────────────────────────
buildDomainBars();
buildCatBtns();
filterFC();
buildQuizSetup();
</script>
